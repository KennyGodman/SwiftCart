# ── ArcWear Environment Variables ──────────────────────────
# Copy this to .env and fill in your values.

# ── Brevo (order confirmation emails) ───────────────────────
BREVO_API_KEY=your_brevo_api_key_here

# ── Groq (AI agent LLM) ─────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Circle Programmable Wallets (autonomous checkout) ────────
# 1. Sign up at https://console.circle.com/
# 2. Create a project → copy your API Key below
# 3. Run `node scripts/circle-setup.mjs` to generate the rest
CIRCLE_API_KEY=your_circle_api_key_here

# 64-char hex (32 bytes) — generated by circle-setup.mjs if left blank
CIRCLE_ENTITY_SECRET=your_64_char_hex_entity_secret_here

# UUID — output of circle-setup.mjs ("Wallet ID: ...")
CIRCLE_WALLET_ID=your_circle_wallet_uuid_here

# Wallet Set UUID — output of circle-setup.mjs
CIRCLE_WALLET_SET_ID=your_circle_wallet_set_uuid_here

# Blockchain address of the agent wallet — update config.js with this too
CIRCLE_AGENT_ADDRESS=0xc83e6b9a6aa46a09b1fb28c5bce7e8e74bacd488

# ── Vercel Cron Security (optional) ─────────────────────────
# Set a random string here; pass it as Authorization: Bearer <secret>
# when manually triggering POST /api/agent-cron
CRON_SECRET=your_random_cron_secret_here
